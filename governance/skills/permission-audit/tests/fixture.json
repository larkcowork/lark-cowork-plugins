{
  "_comment": "permission-audit: read-only DLP scan. Lists via search verbs (no list verbs in CLI for these surfaces).",
  "skill": "permission-audit",
  "calls": [
    {
      "service": "lark-drive",
      "verb": "search",
      "flags": [
        "--doc-types",
        "--folder-tokens"
      ]
    },
    {
      "service": "lark-base",
      "verb": "table-list",
      "flags": [
        "--base-token"
      ]
    },
    {
      "service": "lark-doc",
      "verb": "fetch",
      "flags": [
        "--api-version",
        "--doc"
      ]
    }
  ],
  "expected_output": [
    "Read-only scan",
    "CRIT",
    "HIGH",
    "MED",
    "READ-ONLY",
    "Mask sensitive data"
  ]
}
