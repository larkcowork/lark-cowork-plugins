{
  "_comment": "daily-digest: end-of-day wrap across calendar + tasks + optional mail.",
  "skill": "daily-digest",
  "calls": [
    {
      "service": "lark-calendar",
      "verb": "agenda",
      "flags": [
        "--start",
        "--end"
      ]
    },
    {
      "service": "lark-task",
      "verb": "search",
      "flags": [
        "--completed",
        "--due"
      ]
    },
    {
      "service": "lark-task",
      "verb": "get-my-tasks",
      "flags": [
        "--complete",
        "--due-end"
      ]
    }
  ],
  "expected_output": [
    "End-of-day",
    "Done today",
    "Still open"
  ]
}
